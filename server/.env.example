# MongoDB Configuration
# For local MongoDB: mongodb://localhost:27017/virtual-classroom
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/virtual-classroom

# JWT Configuration
# Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_here_change_this_in_production
JWT_EXPIRE=7d

# Server Configuration
PORT=5000
NODE_ENV=development

# Client Configuration (for CORS)
FRONTEND_URL=http://localhost:5173
